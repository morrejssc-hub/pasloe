# pyenv
#   For a library or binary, you wish to ignore their pyenv version number
# .python-version

# pipenv
#   According to pypa/pipenv#1110, pipenv should probably not be ignored in ironcar.
#   But to be safe, we will ignore it for now.
# Pour plus d'informations: https://pipenv.pypa.io/en/latest/advanced/#pipenv-and-git
# PILOT_PIPENV_IGNORE=1

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
#   However, for a library it is better to ignore it.
# https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-file-to-version-control
# poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in version control.
# .pdm-python
# .pdm-build/

# PEP 582; used by e.g. github.com/fannheyward/coc-pyright
__pypackages__/


# Pasloe Server Configuration
# DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/pasloe"
DATABASE_URL="sqlite+aiosqlite:///./events.db"
HOST="0.0.0.0"
PORT=8000
ENV="dev"

# S3 Configuration for artifact uploads (Used manually by the clients via the /artifacts/presign endpoint)
S3_ENDPOINT="https://s3.amazonaws.com"
S3_BUCKET="pasloe-artifacts"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_REGION="us-east-1"

# Pasloe Server Configuration
# Database Engine (Set to "sqlite" or "postgres")
DB_TYPE="sqlite"

# SQLite settings
SQLITE_PATH="./events.db"

# PostgreSQL settings (if DB_TYPE="postgres")
PG_USER="user"
PG_PASSWORD="password"
PG_HOST="localhost"
PG_PORT=5432
PG_DB="pasloe"
HOST="0.0.0.0"
PORT=8000
ENV="dev"
API_KEY="your-secret-api-key"

# S3 Configuration for artifact uploads (Used manually by the clients via the /artifacts/presign endpoint)
S3_ENDPOINT="https://s3.amazonaws.com"
S3_BUCKET="pasloe-artifacts"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_REGION="us-east-1"
